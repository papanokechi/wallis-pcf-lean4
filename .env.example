# SIARC — Self-Improving Autonomous Research Chain
# Copy this file to .env and fill in your API key(s).
#
#   cp .env.example .env
#
# The only REQUIRED key is ANTHROPIC_API_KEY (for discovery_loop.py / Agent C API mode).
# All other agents run locally with mpmath + sympy (no API needed).

ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# Optional: OpenAI for breakthrough_engine fallback
# OPENAI_API_KEY=sk-REPLACE_ME

# Multi-agent discussion system defaults (multi_agent_discussion/controller.py)
# Requires both ANTHROPIC_API_KEY and OPENAI_API_KEY for live runs.
# OPENAI_MODEL=gpt-4o
# ANTHROPIC_MODEL=claude-opus-4-5
# DEBATE_MAX_ITERATIONS=4

# Optional SIARC Agent D debate critic integration
# SIARC_USE_DEBATE_CRITIC=1
# SIARC_DEBATE_DRY_RUN=1
# SIARC_DEBATE_ITERATIONS=3
# SIARC_OPENAI_MODEL=gpt-4o
# SIARC_ANTHROPIC_MODEL=claude-opus-4-5
# SIARC_SWARM_MODE=1
# SIARC_SWARM_SIZE=6
# SIARC_SWARM_SURVIVORS=2

# Optional: Compute budget overrides (seconds)
# SIARC_COMPUTE_BUDGET=600
# SIARC_MAX_CYCLES=50

# Enable launch.json --input file compatibility:
# Mirrors agent output JSON to workspace root (agent_A_out.json, etc.)
# Set to 1 if you use the VS Code launch profiles that chain agents via --input flags.
SIARC_ROOT_MIRROR=1

# Force Python UTF-8 mode on Windows (needed for Unicode symbols in output)
PYTHONUTF8=1

