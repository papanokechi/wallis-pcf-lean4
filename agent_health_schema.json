{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/agent_health_schema.json",
  "title": "Agent Health Score History",
  "type": "object",
  "required": ["version", "updated_at", "config", "claims", "sessions", "rolling"],
  "properties": {
    "version": {"type": "integer", "minimum": 1},
    "updated_at": {"type": "string", "minLength": 1},
    "config": {
      "type": "object",
      "required": ["window_days", "max_sessions", "depth_floor_digits", "overall_formula"],
      "properties": {
        "window_days": {"type": "integer", "minimum": 1},
        "max_sessions": {"type": "integer", "minimum": 1},
        "depth_floor_digits": {"type": "number", "minimum": 1},
        "rolling_half_life_days": {"type": "number", "minimum": 1},
        "overall_formula": {"type": "string"},
        "axis_formulas": {"type": "object"},
        "grade_bands": {"type": "object"}
      },
      "additionalProperties": true
    },
    "claims": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "entry_id",
          "timestamp",
          "agent_id",
          "session_id",
          "status",
          "fabrication_score",
          "depth_score",
          "honesty_score"
        ],
        "properties": {
          "entry_id": {"type": "string", "minLength": 1},
          "timestamp": {"type": "string", "minLength": 1},
          "agent_id": {"type": "string", "minLength": 1},
          "session_id": {"type": "string", "minLength": 1},
          "git_commit": {"type": "string"},
          "claim_path": {"type": "string"},
          "status": {
            "type": "string",
            "enum": ["VERIFIED", "MISMATCH", "EXECUTION_FAILED", "SCHEMA_INVALID"]
          },
          "evidence_class": {"type": "string"},
          "claimed_digits": {"type": "number", "minimum": 0},
          "actual_digits": {"type": "number", "minimum": 0},
          "threshold": {"type": "number", "minimum": 0},
          "threshold_met_claimed": {"type": "boolean"},
          "threshold_met_actual": {"type": "boolean"},
          "fabrication_score": {"type": "number", "minimum": 0, "maximum": 100},
          "depth_score": {"type": "number", "minimum": 0, "maximum": 100},
          "honesty_score": {"type": "number", "minimum": 0, "maximum": 100}
        },
        "additionalProperties": true
      }
    },
    "sessions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["agent_id", "session_id", "claim_count", "axes", "score", "grade", "trust_mode"],
        "properties": {
          "agent_id": {"type": "string", "minLength": 1},
          "session_id": {"type": "string", "minLength": 1},
          "git_commit": {"type": "string"},
          "started_at": {"type": "string"},
          "ended_at": {"type": "string"},
          "claim_count": {"type": "integer", "minimum": 0},
          "counts": {"type": "object"},
          "axes": {
            "type": "object",
            "required": ["fabrication", "depth", "honesty"],
            "properties": {
              "fabrication": {"type": "number", "minimum": 0, "maximum": 100},
              "depth": {"type": "number", "minimum": 0, "maximum": 100},
              "honesty": {"type": "number", "minimum": 0, "maximum": 100}
            }
          },
          "score": {"type": "number", "minimum": 0, "maximum": 100},
          "grade": {"type": "string", "enum": ["A", "B", "C", "D", "F"]},
          "trust_mode": {"type": "string"}
        },
        "additionalProperties": true
      }
    },
    "rolling": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["agent_id", "window_days", "max_sessions", "session_count", "axes", "score", "grade", "trust_mode"],
        "properties": {
          "agent_id": {"type": "string", "minLength": 1},
          "window_days": {"type": "integer", "minimum": 1},
          "max_sessions": {"type": "integer", "minimum": 1},
          "session_count": {"type": "integer", "minimum": 0},
          "axes": {
            "type": "object",
            "required": ["fabrication", "depth", "honesty"],
            "properties": {
              "fabrication": {"type": "number", "minimum": 0, "maximum": 100},
              "depth": {"type": "number", "minimum": 0, "maximum": 100},
              "honesty": {"type": "number", "minimum": 0, "maximum": 100}
            }
          },
          "score": {"type": "number", "minimum": 0, "maximum": 100},
          "grade": {"type": "string", "enum": ["A", "B", "C", "D", "F"]},
          "trust_mode": {"type": "string"}
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}