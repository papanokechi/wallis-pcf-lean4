  "experiment_protocol": {
    "target": "H3.1",
    "model": "Llama-3-8B or Mistral-7B chat",
    "benchmark": "JailbreakBench JBB-Behaviors",
    "steps": [
      {
        "id": 1,
        "name": "Pilot Run",
        "prompts": 100,
        "gpu_hours": "1-2",
        "description": "50 harmful + 50 benign prompts. Record top-k logprobs, compute all 4 entropy features + 4 AAD features."
      },
      {
        "id": 2,
        "name": "Threshold Tuning",
        "prompts": 100,
        "gpu_hours": "included",
        "description": "Compute AUROC for each of 8 features independently and combined logistic regression."
      },
      {
        "id": 3,
        "name": "Full Test",
        "prompts": 400,
        "gpu_hours": "4-8",
        "description": "Held-out 30% test split. Report AUROC with 95% bootstrap CI."
      },
      {
        "id": 4,
        "name": "Robustness Checks",
        "prompts": 1600,
        "gpu_hours": "16-32",
        "description": "2 decoding modes × 2 top-k values. Report AUROC per condition."
      },
      {
        "id": 5,
        "name": "Ablations",
        "prompts": 400,
        "gpu_hours": "4-8",
        "description": "Test entropy features vs AAD features vs combined. Feature importance analysis."
      },
      {
        "id": 6,
        "name": "Decision Rule",
        "prompts": 0,
        "gpu_hours": "0",
        "description": "AUROC >= 0.85 on held-out test, stable across top-k choices (drop <= 0.05)."
      }
    ],
    "total_compute_estimate": "24-50 GPU Hours",
    "kill_condition": "AUROC < 0.85"
  },
  "backpressure": {
    "target_survivor_rate": 0.25,
    "k_initial": 20,
    "x0_initial": 0.75,
    "k_bounds": [5, 50],
    "x0_bounds": [0.60, 0.90],
    "eta": 2.0,
    "lambda": 0.05,
    "update_rule": "k_{t+1} = k_t + η × (survivor_rate_t − target_rate)"
  },
  "activation_anomaly_detector": {
    "equation": "IF_t = 1 - cos(h_t^(l), h_t^(l+1))",
    "aggregations": {
      "max_IF": "max(IF) — global spike",
      "safety_bottleneck": "argmax_l(mean(IF[l,:])) — which layer carries refusal",
      "mean_IF_spike": "mean(IF[l_safety,:]) — sustained conflict",
      "IF_gradient_max": "max(d(IF)/dt) — moment of compliance"
    },
    "target_layers": "middle-to-late (typically layers 16-28 in 32-layer model)"
  },
  "meta_skeptic": {
    "audit_queries": [
      {
        "name": "Vacuousness Test",
        "failure_mode": "Kill floor impossible to trigger",
        "metric": "Variance(score_dist) > 0.1"
      },
      {
        "name": "Tautology Check",
        "failure_mode": "Hypothesis true by definition",
        "metric": "Successful mapping to existing literature (non-circular)"
      },
      {
        "name": "Sensitivity Check",
        "failure_mode": "1% data change flips score",
        "metric": "High gradient of B_soft near x0"
      },
      {
        "name": "Collusion Detector",
        "failure_mode": "Generator gaming the filter",
        "metric": "KL(P_killed || P_survived) > threshold"
      },
      {
        "name": "Justification Depth",
        "failure_mode": "Score justifications restate rubric instead of citing data",
        "metric": "External reference count per justification >= 2"
      }
    ]
  },
